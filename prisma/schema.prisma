generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  debates   Debate[]
  tickers   Ticker[]
  createdAt DateTime @default(now())
}

model Ticker {
  id        String        @id @default(cuid())
  symbol    String        @db.VarChar(10)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     TradingNote[] 
  debates   Debate[]      
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([userId, symbol]) 
  @@index([userId])
}

model TradingNote {
  id        String      @id @default(cuid())
  userId    String   
  tickerId  String   
  ticker    Ticker      @relation(fields: [tickerId], references: [id], onDelete: Cascade)
  content   String      @db.Text
  chunks    NoteChunk[] 
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId, tickerId]) 
}

model NoteChunk {
  id            String      @id @default(cuid())
  noteId        String
  note          TradingNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  chunkContent  String      @db.Text

  @@index([noteId])
}

model Debate {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  tickerId     String   
  ticker       Ticker   @relation(fields: [tickerId], references: [id], onDelete: Cascade)
  userQuery    String
  bullResponse Json     
  bearResponse Json     
  judgeVerdict Json     
  createdAt    DateTime @default(now())

  @@index([userId, tickerId])
}