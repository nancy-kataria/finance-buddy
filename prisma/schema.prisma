generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  debates   Debate[]
}

model Debate {
  id           String   @id @default(cuid())
  userId       String
  userQuery    String
  bullResponse String   @db.Text
  bearResponse String   @db.Text
  judgeVerdict String   @db.Text
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model FinancialInsight {
  id        String   @id @default(uuid())
  content   String
  metadata  Json?
  createdAt DateTime @default(now())
}
